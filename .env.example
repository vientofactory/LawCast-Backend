# 서버 설정
PORT=3001
NODE_ENV=production

# 데이터베이스 설정
DATABASE_PATH=lawcast.db

# Redis 캐시 설정
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lawcast:
REDIS_TTL=1800

# HashGuard(PoW) API 설정 (선택사항)
HASHGUARD_API_URL=https://hashguard.viento.me

# Ollama 요약 API 설정 (선택사항)
OLLAMA_ENABLED=true
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b # 명시하지 않을 경우 기본값으로 gemma3:1b 사용
OLLAMA_TIMEOUT=10000

# 크론 작업 시간대
CRON_TIMEZONE=Asia/Seoul

# CORS 허용 도메인 (쉼표로 구분)
FRONTEND_URL=http://localhost:5173,http://localhost:3002

# Discord 디버그 브릿지 (선택사항)
# 브릿지 전체 활성화 여부
DISCORD_BRIDGE_ENABLED=false
# Discord 봇 토큰 (Discord Developer Portal > Bot > Token)
DISCORD_BRIDGE_BOT_TOKEN=
# 길드(서버) ID — 설정 시 슬래시 명령어가 해당 길드에 즉시 등록됨
# 미설정 시 글로벌 등록 (전파까지 최대 1시간 소요)
DISCORD_BRIDGE_GUILD_ID=
# 명령어를 수신할 브릿지 채널 ID (Snowflake)
DISCORD_BRIDGE_CHANNEL_ID=
# 이벤트 로그를 전송할 로그 채널 ID (Snowflake)
DISCORD_BRIDGE_LOG_CHANNEL_ID=
# 로그 레벨: ERROR | WARN | LOG | DEBUG | VERBOSE (기본값: LOG)
DISCORD_BRIDGE_LOG_LEVEL=LOG
# 브릿지 명령어를 사용할 수 있는 Discord 유저 ID (쉼표로 구분)
DISCORD_BRIDGE_ADMIN_USER_IDS=
